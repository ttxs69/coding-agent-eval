# Python
__pycache__/
*.pyc
*.pyo

# Virtual environments
.venv/
venv/
env/

# Build / packaging artifacts
*.egg-info/
build/
dist/

# Generated static site (output of `cae build-site`)
site/

# Eval runtime artifacts (harness writes result JSONs; importer populates task dirs)
# .gitkeep preserved so the empty `results/` directory ships in the repo.
results/*.json
tasks/

# Test / cache artifacts
.pytest_cache/
.ruff_cache/

# MemPalace per-project files (issue #185)
mempalace.yaml
entities.json

# self-improve skill runtime artifacts (local automation state, not committed)
.claude/self-improve-state.md
.claude/self-improve-state.md.tmp
.claude/worktrees/

# self-improve fixture's lockfile (synthetic test fixture; lockfile is
# regenerated by `uv pip install -e .` inside the fixture, not committed)
tests/fixtures/self-improve-sample-project/uv.lock
